file(MAKE_DIRECTORY "@EXPORT_DIRECTORY@")

set(EXPORT_HEX_FILES "@EXPORT_HEX_FILES@")

foreach(hex_file IN LISTS EXPORT_HEX_FILES)
    get_filename_component(hex_name "${hex_file}" NAME)
    execute_process(
        COMMAND "${CMAKE_COMMAND}" -E copy_if_different "${hex_file}" "@EXPORT_DIRECTORY@/${hex_name}"
        COMMAND_ERROR_IS_FATAL ANY
    )
endforeach()
